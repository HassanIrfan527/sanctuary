{
    "positionX": "right",
    "positionY": "top",
    "layer": "overlay",
    "control-center-width": 380,
    "notification-window-width": 360,
    "notification-icon-size": 48,
    "timeout": 6,
    "timeout-low": 4,
    "timeout-critical": 0,
    "fit-to-screen": true,
    "relative-timestamps": true,
    "hide-on-clear": true,
    "hide-on-action": true,
    "widgets": ["title", "dnd", "notifications"],
    "widget-config": {
        "title": {
            "text": "Notifications",
            "clear-all-button": true,
            "button-text": "Clear"
        },
        "dnd": {
            "text": "Do Not Disturb"
        }
    }
}
