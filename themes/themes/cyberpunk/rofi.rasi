/* Cyberpunk — Dracula+Neon on black */
* {
    bg: rgba(13, 13, 13, 0.96);
    fg: #f8f8f2;
    accent: #ff79c6;
    muted: #6272a4;
}

window {
    border-radius: 4px;
    border: 1px solid rgba(255, 121, 198, 0.4);
}

element {
    border-radius: 2px;
}

element selected {
    background-color: rgba(255, 121, 198, 0.15);
}

element-text selected {
    color: #50fa7b;
}

inputbar {
    border-color: rgba(255, 121, 198, 0.3);
}

entry {
    color: #f8f8f2;
}

prompt {
    color: #ff79c6;
}
