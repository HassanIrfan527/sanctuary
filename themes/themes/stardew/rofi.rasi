/* Stardew rofi — sharp, pixelated */
* {
    bg: rgba(27, 29, 46, 0.96);
    fg: #edf2f4;
    accent: #52b788;
    muted: #4a4e69;
}

window {
    border-radius: 0;
    border: 2px solid rgba(82, 183, 136, 0.3);
}

element {
    border-radius: 0;
}

inputbar {
    border: 0 0 2px 0;
    border-color: rgba(82, 183, 136, 0.2);
}
